// Categorías que NO van al inventario de alimentos ni al dropdown del menú
const NON_FOOD_CATS=new Set(['Aseo','Hogar','Medicamentos','Otro no alimentario']);

async function addCompra(){
  const nombre=document.getElementById('c-nombre').value.trim();
  const costo=parseFloat(document.getElementById('c-costo').value)||0;
  if(!nombre)return;
  const fechaInput=document.getElementById('c-fecha').value;
  const fecha=fechaInput||new Date().toISOString().slice(0,10);
  const fechaDisplay=new Date(fecha+'T12:00:00').toLocaleDateString('es-CO',{day:'numeric',month:'short',year:'numeric'});
  const cantidadNum=parseFloat(document.getElementById('c-qty').value)||1;
  const unidad=document.getElementById('c-unit').value;
  const tienda=document.getElementById('c-tienda').value.trim()||'—';
  const categoria=document.getElementById('c-cat').value;

  const row={nombre,categoria,cantidad:String(cantidadNum),unidad,costo,tienda,fecha:fechaDisplay,fecha_iso:fecha};
  const{data,error}=await sb.from('compras').insert(row).select().single();
  if(!error&&data){
    comprasCache.unshift(data);

    // Solo agregar al inventario si es categoría alimentaria
    if(!NON_FOOD_CATS.has(categoria)){
      const existing=inventarioCache.find(x=>x.nombre.toLowerCase()===nombre.toLowerCase());
      if(existing){
        const newQty=Math.round((Number(existing.cantidad)+cantidadNum)*100)/100;
        await sb.from('inventario').update({cantidad:String(newQty),unidad,tienda}).eq('id',existing.id);
        existing.cantidad=String(newQty);
        existing.unidad=unidad;
        existing.tienda=tienda;
      }else{
        const{data:invData}=await sb.from('inventario').insert({nombre,cantidad:String(cantidadNum),unidad,tienda}).select().single();
        if(invData) inventarioCache.push(invData);
      }
      toast('Compra guardada ✓ (agregada al inventario)');
    }else{
      toast('Compra guardada ✓ (solo presupuesto, no inventario)');
    }

    ['c-nombre','c-qty','c-costo','c-tienda'].forEach(id=>document.getElementById(id).value='');
    renderCompras();
    updatePresUI();
    updateDailyTotal();
    renderCharts();
  }else toast('Error',true);
}
async function delCompra(id){
  const c=comprasCache.find(x=>x.id===id);
  await sb.from('compras').delete().eq('id',id);
  comprasCache=comprasCache.filter(x=>x.id!==id);

  // Intentar eliminar también del inventario
  if(c){
    const inv=inventarioCache.find(x=>x.nombre.toLowerCase()===c.nombre.toLowerCase());
    if(inv){
      const{error}=await sb.from('inventario').delete().eq('id',inv.id);
      if(!error){
        inventarioCache=inventarioCache.filter(x=>x.id!==inv.id);
        toast('Eliminado de compras e inventario');
