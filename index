// Convierte cualquier unidad a su valor decimal
// "unidad" → 1, "½ unidad" → 0.5, "¼ litro" → 0.25, "¾ libra" → 0.75
function unitToDecimal(unidadStr){
  if(!unidadStr) return 1;
  const s=unidadStr.trim();
  if(s.startsWith('½')) return 0.5;
  if(s.startsWith('¼')) return 0.25;
  if(s.startsWith('¾')) return 0.75;
  return 1;
}

// Formatea un número decimal a string legible
function formatQty(num){
  const n=Math.round(num*100)/100;
  if(n===0) return '0';
  if(n===0.25) return '¼';
  if(n===0.5)  return '½';
  if(n===0.75) return '¾';
  if(n===1)    return '1';
  if(n===1.25) return '1¼';
  if(n===1.5)  return '1½';
  if(n===1.75) return '1¾';
  if(n===2)    return '2';
  if(n===2.5)  return '2½';
  if(n%1===0)  return String(n);
  return n.toFixed(2);
}

