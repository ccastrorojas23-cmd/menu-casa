  const catMap={};
  comprasCache.forEach(c=>{const cat=c.categoria||'Otro';catMap[cat]=(catMap[cat]||0)+Number(c.costo);});
  const catEntries=Object.entries(catMap).sort((a,b)=>b[1]-a[1]);
