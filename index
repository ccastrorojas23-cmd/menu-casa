        plugins:{legend:{display:false}},
        scales:{x:{ticks:{callback:v=>'$'+v.toLocaleString('es-CO')},grid:{color:'rgba(0,0,0,.05)'}},y:{grid:{display:false},ticks:{font:{size:11}}}}
      }
    });
