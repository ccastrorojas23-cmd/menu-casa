async function discountFromInventory(nombre,qty,unitStr,tipo){
  const realQty=(Number(qty)||1)*unitToDecimal(unitStr);
  if(realQty<=0) return;
  const item=inventarioCache.find(x=>x.nombre.toLowerCase()===nombre.toLowerCase());
  if(!item) return;
  const newQty=Math.max(0,Math.round((Number(item.cantidad)-realQty)*100)/100);
  await sb.from('inventario').update({cantidad:String(newQty)}).eq('id',item.id);
  item.cantidad=String(newQty);
}

async function returnToInventory(nombre,qty,unitStr,tipo){
  const realQty=(Number(qty)||1)*unitToDecimal(unitStr);
  if(realQty<=0) return;
  const item=inventarioCache.find(x=>x.nombre.toLowerCase()===nombre.toLowerCase());
  if(!item) return;
  const newQty=Math.round((Number(item.cantidad)+realQty)*100)/100;
  await sb.from('inventario').update({cantidad:String(newQty)}).eq('id',item.id);
  item.cantidad=String(newQty);
}

