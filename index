                    preparadoCache[`${qKey}-${diaName}`]?.preparado===true;
  let mealsHtml='';
  COMIDAS.forEach(c=>{
    // New key uses isoDate; fall back to old key for existing data
    const mKey=`${isoDate}-${c.key}`;
    const oldKey=`${qKey}-${diaName}-${c.key}`;
    const m=menuCache[mKey]||menuCache[oldKey]||{texto:'',ingredientes:[]};
