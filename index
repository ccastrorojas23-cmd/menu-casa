function scheduleSave(mKey,value){
  if(!menuCache[mKey])menuCache[mKey]={texto:'',ingredientes:[],db_id:null};
  menuCache[mKey].texto=value;
  clearTimeout(saveTimers[mKey]);
  saveTimers[mKey]=setTimeout(()=>saveMealDB(mKey,value),800);
}
async function saveMealDB(mKey,value){
  const lastDash=mKey.lastIndexOf('-');
  const fechaIso=mKey.slice(0,lastDash);
  const comida=mKey.slice(lastDash+1);
  const{error}=await sb.from('menu_semana').upsert(
    {fecha_iso:fechaIso,comida,texto:value,updated_at:new Date().toISOString()},
    {onConflict:'fecha_iso,comida',ignoreDuplicates:false}
  );
  if(error){console.error('saveMealDB error:',error);toast('Error al guardar',true);}
  else toast('Guardado');
  buildDaysList();
}

