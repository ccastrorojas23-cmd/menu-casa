function findFavByTexto(texto){
  if(!texto||!texto.trim()) return null;
  const t=texto.trim().toLowerCase();
  return Object.values(favoritosCache).find(f=>f.nombre.trim().toLowerCase()===t)||null;
}

async function toggleFavFromMeal(mKey,comidaKey){
  const m=menuCache[mKey];
  if(!m||!m.texto.trim()){toast('Escribe primero el nombre de la receta',true);return;}

  const existing=findFavByTexto(m.texto);
  if(existing){
    // Already favourite → remove
    const ok=await conf('⭐ Quitar favorito',`¿Eliminar "${existing.nombre}" de tus recetas favoritas?`);
    if(!ok)return;
    await sb.from('recetas_favoritas').delete().eq('id',existing.id);
    delete favoritosCache[existing.id];
    toast('Quitado de favoritos');
  }else{
    // Save as favourite
    const row={
      nombre: m.texto.trim(),
      descripcion: '',
      comida: comidaKey,
      ingredientes: m.ingredientes.map(i=>({nombre:i.nombre,cantidad:i.cantidad,unidad:i.unidad,tipo:i.tipo})),
      veces_usada: 1
    };
    const{data,error}=await sb.from('recetas_favoritas').insert(row).select().single();
    if(!error&&data){
      favoritosCache[data.id]=data;
      toast('⭐ Guardado en favoritos');
    }else{toast('Error al guardar',true);return;}
  }
  // Refresh star button
  const btn=document.getElementById(`fav-btn-${mKey}`);
  if(btn){
    const nowFav=!!findFavByTexto(m.texto);
    btn.className=`ms-fav-btn ${nowFav?'active':''}`;
    btn.textContent=nowFav?'⭐':'☆';
    btn.title=nowFav?'Quitar de favoritos':'Guardar como favorito';
  }
}

async function deleteFav(id){
  const ok=await conf('🗑️ Eliminar favorito','¿Eliminar esta receta de tus favoritos?');
  if(!ok)return;
  await sb.from('recetas_favoritas').delete().eq('id',id);
  delete favoritosCache[id];
  toast('Favorito eliminado');
  renderFavoritos();
}

async function usarFavorito(id){
  // Increment usage counter
  const fav=favoritosCache[id];
  if(!fav)return;
  const newCount=(fav.veces_usada||0)+1;
  await sb.from('recetas_favoritas').update({veces_usada:newCount}).eq('id',id);
  favoritosCache[id].veces_usada=newCount;
  toast(`"${fav.nombre}" — puedes copiarla al menú escribiéndola en el día que quieras`);
  renderFavoritos();
}

function renderFavoritos(){
  const grid=document.getElementById('fav-grid');
  const filtroComida=document.getElementById('fav-filter-comida').value;
  const filtroTexto=(document.getElementById('fav-search').value||'').toLowerCase();
  const COMIDA_ICONS={desayuno:'☕',almuerzo:'🍽️',comida:'🌙'};
  const COMIDA_LABELS={desayuno:'Desayuno',almuerzo:'Almuerzo',comida:'Comida'};

  let favs=Object.values(favoritosCache);
  if(filtroComida) favs=favs.filter(f=>f.comida===filtroComida);
  if(filtroTexto) favs=favs.filter(f=>f.nombre.toLowerCase().includes(filtroTexto)||(f.descripcion||'').toLowerCase().includes(filtroTexto));
  // Sort: most used first
  favs.sort((a,b)=>(b.veces_usada||0)-(a.veces_usada||0));

  if(!favs.length){
    grid.innerHTML=`<div class="fav-empty">
      <div class="fav-empty-icon">⭐</div>
      <p style="font-size:.9rem;font-weight:600;color:var(--ink);">Sin recetas favoritas aún</p>
      <p style="font-size:.82rem;">Abre un día del menú, escribe una receta<br>y presiona ☆ para guardarla aquí.</p>
    </div>`;
    return;
  }

  grid.innerHTML=favs.map(f=>{
    const icon=COMIDA_ICONS[f.comida]||'🍽️';
    const label=COMIDA_LABELS[f.comida]||f.comida;
    const ings=(f.ingredientes||[]);
    const ingsHtml=ings.map(i=>`<span class="fav-ing-chip ${i.tipo||'comprado'}">${esc(i.nombre)} · ${i.cantidad} ${i.unidad}</span>`).join('');
    return`<div class="fav-card">
      <div class="fav-card-header">
        <div class="fav-card-comida">${icon} ${label}</div>
        <div class="fav-card-actions">
          <button class="fav-star-btn" title="Quitar de favoritos" onclick="deleteFav('${f.id}')">🗑️</button>
        </div>
      </div>
      <div class="fav-card-body">
        <div class="fav-nombre">${esc(f.nombre)}</div>
        ${f.descripcion?`<div class="fav-desc">${esc(f.descripcion)}</div>`:''}
        ${ings.length?`<div class="fav-ings">${ingsHtml}</div>`:'<div class="fav-ings" style="color:var(--muted);font-size:.76rem;">Sin ingredientes guardados</div>'}
        <div class="fav-usada">Usada ${f.veces_usada||1} ${(f.veces_usada||1)===1?'vez':'veces'}</div>
      </div>
    </div>`;
  }).join('');
