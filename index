async function togglePreparado(isoDate,diaName,qKey){
  const current=preparadoCache[isoDate];
  const nuevoEstado=!(current?.preparado===true);

  if(nuevoEstado){
    const ok=await conf(
      '🍳 Marcar como preparado',
      `Los ingredientes de ${diaName} se marcarán como utilizados. ¿Continuar?`
    );
    if(!ok)return;
  }

  let id=current?.id||null;
  if(id){
    await sb.from('dias_preparados').update({preparado:nuevoEstado}).eq('id',id);
  }else{
    const{data}=await sb.from('dias_preparados').insert({
      fecha_iso:isoDate,quincena:qKey,dia:diaName,preparado:nuevoEstado
    }).select().single();
    if(data)id=data.id;
  }
  preparadoCache[isoDate]={id,preparado:nuevoEstado};

  if(nuevoEstado) toast(`${diaName} marcado como preparado 🍳`);
  else toast(`${diaName} desmarcado`);

  const btn=document.getElementById(`btn-preparado-${isoDate}`);
  if(btn){
    btn.className=`btn btn-sm ${nuevoEstado?'btn-preparado-on':'btn-preparado-off'}`;
    btn.textContent=nuevoEstado?'🍳 Preparado — desmarcar':'🍳 Marcar preparado';
  }
  buildDaysList();
}

