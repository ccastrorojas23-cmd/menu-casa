    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9de8d0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
    Menú Casa
  </div>
  <div class="mob-right">
    <div class="mob-pres" onclick="openBudgetModal()">$<span id="hdr-pres-mob">0</span></div>
    <span class="sync-dot" id="sync-led-mob"></span>
  </div>
</div>

<!-- MOBILE DRAWER OVERLAY -->
<div class="mob-overlay" id="mob-overlay" onclick="closeMobMenu()"></div>
<div class="mob-drawer" id="mob-drawer">
  <div class="mob-drawer-item on" onclick="showSec('menu',this);closeMobMenu()">
    <svg class="di-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>Menú
  </div>
  <div class="mob-drawer-item" onclick="showSec('favoritos',this);closeMobMenu()">
    <svg class="di-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>Recetas favoritas
  </div>
