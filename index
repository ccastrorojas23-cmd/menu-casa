// ══════════════════════════════════════
function setQ(q,el){
  currentQ=q;
  document.querySelectorAll('.q-tab').forEach(t=>t.classList.remove('on'));
  el.classList.add('on');
  activeDay=null;
  closePanel();
  buildMosaic();
}

function getQDates(){
  const today=new Date();
  const dow=today.getDay();
  const monday=new Date(today);
  monday.setDate(today.getDate()-(dow===0?6:dow-1));
  const offset=(currentQ-1)*15;
  const start=new Date(monday);
  start.setDate(monday.getDate()+offset);
  const dates=[];
  for(let i=0;i<15;i++){
    const d=new Date(start);
    d.setDate(start.getDate()+i);
    const dayIdx=d.getDay();
    const isoDate=d.toISOString().slice(0,10);
    dates.push({date:d,isoDate,diaName:DIAS[dayIdx===0?6:dayIdx-1],isToday:d.toDateString()===today.toDateString()});
  }
  return dates;
}

// Alias for compatibility
function buildDaysList(){ buildMosaic(); }

function buildMosaic(){
  const wrap=document.getElementById('menu-mosaic');
  if(!wrap) return;
  wrap.innerHTML='';
  const qKey=`Q${currentQ}`;
  getQDates().forEach((entry,idx)=>{
    const{date,isoDate,diaName,isToday}=entry;
    const dateStr=date.toLocaleDateString('es-CO',{day:'numeric',month:'short'});
    const isPreparado=preparadoCache[isoDate]?.preparado===true||
                      preparadoCache[`${qKey}-${diaName}`]?.preparado===true;
    const isActive=activeDay&&activeDay.isoDate===isoDate;

    // Build meal previews
    const mealsHtml=COMIDAS.map(c=>{
      const mKey=`${isoDate}-${c.key}`;
      const oldKey=`${qKey}-${diaName}-${c.key}`;
      const m=menuCache[mKey]||menuCache[oldKey];
      const texto=m?.texto||'';
      return`<div class="mc-meal">
        <span class="mc-meal-icon">${c.icon}</span>
        <span class="mc-meal-text ${texto?'':'empty'}">${texto?texto.substring(0,18)+(texto.length>18?'…':''):'Sin planificar'}</span>
      </div>`;
    }).join('');

    // Count total ingredients
    const totalIng=COMIDAS.reduce((sum,c)=>{
      const mKey=`${isoDate}-${c.key}`;
      const oldKey=`${qKey}-${diaName}-${c.key}`;
      return sum+((menuCache[mKey]||menuCache[oldKey])?.ingredientes?.length||0);
    },0);

    let statusClass='empty',statusText='Sin planificar';
    const hasAny=COMIDAS.some(c=>{const m=menuCache[`${isoDate}-${c.key}`]||menuCache[`${qKey}-${diaName}-${c.key}`];return m&&m.texto;});
    if(isPreparado){statusClass='prep';statusText='🍳 Preparado';}
    else if(hasAny){statusClass='ok';statusText='✓ Planificado';}

    const card=document.createElement('div');
    card.className=`mosaic-card${isToday?' today':''}${isActive?' active':''}`;
    card.id=`mc-${isoDate}`;
    card.innerHTML=`
      <div class="mc-header">
        <div>
          <div class="mc-day">${diaName}${isToday?'<span class="mc-today-pill" style="margin-left:.35rem;">Hoy</span>':''}</div>
          <div class="mc-date">${dateStr}</div>
        </div>
      </div>
      <div class="mc-body">${mealsHtml}</div>
      <div class="mc-footer">
        <span class="mc-status ${statusClass}">${statusText}</span>
        ${totalIng>0?`<span class="mc-ing-count">${totalIng} ing.</span>`:''}
      </div>`;
    card.onclick=()=>openDayPanel(entry,idx,qKey);
    wrap.appendChild(card);
  });
}

