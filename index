async function saveCompraEdit(id){
  const newQty=document.getElementById(`edit-qty-${id}`).value||'1';
  const newUnit=document.getElementById(`edit-unit-${id}`).value;
  const newCosto=parseFloat(document.getElementById(`edit-costo-${id}`).value)||0;

  const{error}=await sb.from('compras').update({cantidad:newQty,unidad:newUnit,costo:newCosto}).eq('id',id);
  if(error){toast('Error al guardar',true);return;}

  const c=comprasCache.find(x=>x.id===id);
  if(c){c.cantidad=newQty;c.unidad=newUnit;c.costo=newCosto;}

  // También actualizar inventario si existe el artículo
  const inv=inventarioCache.find(x=>x.nombre.toLowerCase()===(c?.nombre||'').toLowerCase());
  if(inv){
    // Recalcular: quitar la cantidad vieja del inventario y poner la nueva
    // Simplificado: actualizar inventario con la nueva cantidad directamente
    await sb.from('inventario').update({cantidad:newQty,unidad:newUnit}).eq('id',inv.id);
    inv.cantidad=newQty;inv.unidad=newUnit;
  }

  toast('Compra actualizada');
  cancelEditCompra(id);
  renderCompras();
  updatePresUI();
  updateDailyTotal();
  renderInventario();
}
async function addCompraToInventario(id){
  const c=comprasCache.find(x=>x.id===id);
  if(!c)return;
  if(NON_FOOD_CATS.has(c.categoria)){
    toast(`"${c.nombre}" es artículo de ${c.categoria} — no se agrega al inventario de alimentos`,true);
    return;
  }
  const qty=parseFloat(c.cantidad)||1;
  const existing=inventarioCache.find(x=>x.nombre.toLowerCase()===c.nombre.toLowerCase());
  if(existing){
    const newQty=Math.round((Number(existing.cantidad)+qty)*100)/100;
    await sb.from('inventario').update({cantidad:String(newQty),unidad:c.unidad||existing.unidad,tienda:c.tienda||existing.tienda}).eq('id',existing.id);
    existing.cantidad=String(newQty);
    existing.unidad=c.unidad||existing.unidad;
    toast(`"${c.nombre}" sumado al inventario — total: ${formatQty(newQty)}`);
  }else{
    const{data}=await sb.from('inventario').insert({nombre:c.nombre,cantidad:String(qty),unidad:c.unidad||'unidad',tienda:c.tienda||''}).select().single();
    if(data) inventarioCache.push(data);
    toast(`"${c.nombre}" agregado al inventario`);
  }
  renderInventario();
}

async function syncAllComprasToInventario(){
  const ok=await conf('📦 Sincronizar todo','Se agregarán todas las compras actuales al inventario, sumando a lo que ya existe. ¿Continuar?');
  if(!ok)return;
  let count=0;
  for(const c of comprasCache){
    // Saltar categorías no alimentarias
    if(NON_FOOD_CATS.has(c.categoria)) continue;
    const qty=parseFloat(c.cantidad)||1;
    const existing=inventarioCache.find(x=>x.nombre.toLowerCase()===c.nombre.toLowerCase());
    if(existing){
      const newQty=Math.round((Number(existing.cantidad)+qty)*100)/100;
      await sb.from('inventario').update({cantidad:String(newQty),unidad:c.unidad||existing.unidad,tienda:c.tienda||existing.tienda}).eq('id',existing.id);
      existing.cantidad=String(newQty);
    }else{
      const{data}=await sb.from('inventario').insert({nombre:c.nombre,cantidad:String(qty),unidad:c.unidad||'unidad',tienda:c.tienda||''}).select().single();
      if(data) inventarioCache.push(data);
    }
    count++;
  }
  toast(`${count} artículo${count!==1?'s':''} sincronizado${count!==1?'s':''} al inventario`);
  renderInventario();
}

function updatePresUI(){
  const gastado=comprasCache.reduce((s,c)=>s+Number(c.costo),0);
  const disp=presupuesto-gastado;
  const pct=presupuesto>0?Math.min(100,Math.round(gastado/presupuesto*100)):0;
  const fmt=n=>n.toLocaleString('es-CO');
  document.getElementById('ps-total').textContent=fmt(presupuesto);
  document.getElementById('ps-gastado').textContent=fmt(gastado);
  document.getElementById('ps-disp').textContent=fmt(Math.abs(disp));
  document.getElementById('hdr-pres').textContent=fmt(presupuesto);
  const mobPres=document.getElementById('hdr-pres-mob');
  if(mobPres) mobPres.textContent=fmt(presupuesto);
  document.getElementById('ps-disp-el').className='ps-val '+(disp>=0?'sage':'neg');
  const bar=document.getElementById('prog-f');
  bar.style.width=pct+'%';
  bar.className='prog-f'+(pct>=90?' danger':'');
  document.getElementById('ps-pct').textContent=pct;
}

function updateDailyTotal(){
  const today=new Date().toISOString().slice(0,10);
  const todayLabel=new Date().toLocaleDateString('es-CO',{day:'numeric',month:'long'});
  const todayTotal=comprasCache
    .filter(c=>(c.fecha_iso||'')===today)
    .reduce((s,c)=>s+Number(c.costo),0);
  const el=document.getElementById('daily-total');
  const dl=document.getElementById('daily-date');
  if(el) el.textContent=todayTotal.toLocaleString('es-CO');
  if(dl) dl.textContent=todayLabel;
}

function scheduleMidnightReset(){
  const now=new Date();
  const midnight=new Date(now);
  midnight.setHours(24,0,0,0);
  const msUntilMidnight=midnight-now;
  setTimeout(()=>{
    updateDailyTotal(); // resets to 0 automatically since no purchases match new date
    scheduleMidnightReset(); // reschedule for next midnight
  },msUntilMidnight);
}
