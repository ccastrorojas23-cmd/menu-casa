async function loadAll(){
  try{
    const [mR,iR,cR,pR,prR,hR,dpR,favR]=await Promise.all([
      sb.from('menu_semana').select('*'),
      sb.from('ingredientes').select('*'),
      sb.from('compras').select('*').order('created_at',{ascending:false}),
      sb.from('pendientes').select('*').order('created_at',{ascending:true}),
      sb.from('presupuesto').select('*').eq('id',1).single(),
      sb.from('historial_compras').select('*').order('archivado_en',{ascending:false}),
      sb.from('dias_preparados').select('*'),
      sb.from('recetas_favoritas').select('*').order('created_at',{ascending:false})
    ]);

    // Inventario — carga separada, no bloquea si la tabla no existe aún
    try{
      const invR=await sb.from('inventario').select('*').order('nombre',{ascending:true});
      inventarioCache=invR.data||[];
    }catch(e){ inventarioCache=[]; console.warn('Tabla inventario no disponible aún',e); }

    menuCache={};
    (mR.data||[]).forEach(r=>{
      // Support both new (fecha_iso) and old (quincena+dia) format
      const k=r.fecha_iso
        ? `${r.fecha_iso}-${r.comida}`
        : `${r.quincena||'Q1'}-${r.dia}-${r.comida}`;
      menuCache[k]={texto:r.texto||'',ingredientes:[],db_id:r.id};
    });
    (iR.data||[]).forEach(i=>{
      const k=i.fecha_iso
        ? `${i.fecha_iso}-${i.comida}`
        : `${i.quincena||'Q1'}-${i.dia}-${i.comida}`;
      if(!menuCache[k])menuCache[k]={texto:'',ingredientes:[],db_id:null};
      menuCache[k].ingredientes.push({
        id:i.id,
        nombre:i.nombre,
        cantidad:Number(i.cantidad)||1,
        unidad:i.unidad||'unidad',
        tipo:i.tipo||'comprado'
      });
    });
    comprasCache=cR.data||[];
    pendientesCache=pR.data||[];
    presupuesto=prR.data?.monto||0;
    histCache=hR.data||[];
    preparadoCache={};
    (dpR.data||[]).forEach(r=>{
      // Support both fecha_iso and old quincena-dia key
      const k=r.fecha_iso||`${r.quincena}-${r.dia}`;
      preparadoCache[k]={id:r.id,preparado:r.preparado};
    });
    favoritosCache={};
    (favR.data||[]).forEach(f=>{
      favoritosCache[f.id]={...f,ingredientes:f.ingredientes||[]};
    });
    document.getElementById('sync-led').className='sync-dot';
    const mobLed=document.getElementById('sync-led-mob');
    if(mobLed) mobLed.className='sync-dot';
  }catch(e){
    document.getElementById('sync-led').className='sync-dot err';
    const mobLed=document.getElementById('sync-led-mob');
    if(mobLed) mobLed.className='sync-dot err';
    console.error(e);
  }
}

