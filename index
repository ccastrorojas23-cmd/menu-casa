let pendingIng={}; // kept for compatibility but unused
let ingQueue={};   // per mKey: [{nombre,tipo,cantidad,unidad}]

function filterIngDD(mKey,query){
  const dd=document.getElementById(`ing-dd-${mKey}`);
  const inputEl=document.getElementById(`ing-search-${mKey}`);
  const q=(query||'').toLowerCase().trim();
  const already=new Set((menuCache[mKey]?.ingredientes||[]).map(x=>x.nombre.toLowerCase()));

  // Comprados = del inventario con cantidad > 0
  const comprados=inventarioCache.filter(c=>
    Number(c.cantidad)>0 &&
    !already.has(c.nombre.toLowerCase()) &&
    (q===''||c.nombre.toLowerCase().includes(q))
  );
  const pends=pendientesCache.filter(p=>
    !p.done &&
    !already.has(p.nombre.toLowerCase()) &&
    (q===''||p.nombre.toLowerCase().includes(q))
  );

  if(!comprados.length&&!pends.length&&!q){
    // Show only the "add new" section when no query and no results
  }else if(!comprados.length&&!pends.length&&q){
    // When typing and no match, still show dropdown with add-new option
  }

  // Position dropdown — open upward if not enough space below
  const rect=inputEl.getBoundingClientRect();
  const ddH=Math.min(380, window.innerHeight*0.45);
  const ddW=Math.min(380, window.innerWidth-24);
  const spaceBelow=window.innerHeight-rect.bottom;
  const spaceAbove=rect.top;

  if(spaceBelow>=Math.min(ddH,200)){
    dd.style.top=(rect.bottom+4)+'px';
    dd.style.maxHeight=Math.min(ddH,spaceBelow-8)+'px';
  }else{
    const availableUp=Math.min(ddH,spaceAbove-8);
    dd.style.top=(rect.top-availableUp-4)+'px';
    dd.style.maxHeight=availableUp+'px';
  }
  // On mobile, center horizontally; on desktop align to input
  if(window.innerWidth<=480){
    dd.style.left='12px';
    dd.style.right='12px';
    dd.style.width='auto';
  }else{
    let left=rect.left;
    if(left+ddW>window.innerWidth-8) left=Math.max(8,window.innerWidth-ddW-8);
    dd.style.left=left+'px';
    dd.style.width=ddW+'px';
  }

  let html='';
  if(comprados.length){
    html+=`<div class="ing-dd-sec">✅ En inventario</div>`;
    html+=comprados.slice(0,12).map(c=>
      `<div class="ing-dd-item" onmousedown="selectIng(event,'${mKey}','${esc(c.nombre)}','comprado','${c.unidad||'unidad'}')">
        <span class="iname">${esc(c.nombre)}</span>
        <span class="istock">${formatQty(Number(c.cantidad))} ${c.unidad||''}</span>
        <span class="badge-comprado">stock: ${formatQty(Number(c.cantidad))}</span>
      </div>`
    ).join('');
  }
  if(pends.length){
    html+=`<div class="ing-dd-sec">⏳ Pendientes por comprar</div>`;
    html+=pends.slice(0,12).map(p=>
      `<div class="ing-dd-item" onmousedown="selectIng(event,'${mKey}','${esc(p.nombre)}','pendiente','${p.unidad||'unidad'}')">
        <span class="iname">${esc(p.nombre)}</span>
        <span class="istock">${p.cantidad||'?'} ${p.unidad||''}</span>
        <span class="badge-pendiente">pendiente</span>
      </div>`
    ).join('');
  }

  // Sección "Agregar nuevo ingrediente" — siempre al final
  html+=`<div class="ing-dd-sec" style="color:var(--rust);background:var(--rust-pale);">➕ ¿No está en la lista? Agrégar como pendiente</div>
    <div class="ing-dd-nuevo" id="nuevo-wrap-${mKey}">
      <input type="text" id="nuevo-nombre-${mKey}"
        placeholder="Nombre del ingrediente…"
        onclick="event.stopPropagation()"
        onkeydown="if(event.key==='Enter'){addNuevoPendiente(event,'${mKey}')}"
        style="width:100%;border:none;border-bottom:1px solid var(--border);border-radius:0;background:var(--surface2);padding:.65rem .85rem;font-size:.85rem;box-shadow:none;">
      <div style="display:flex;gap:.35rem;padding:.5rem .7rem;align-items:center;flex-wrap:wrap;background:var(--surface);">
        <input type="number" id="nuevo-qty-${mKey}" value="1" min="0.01" step="0.01"
          onclick="event.stopPropagation()"
          style="width:65px;font-size:.82rem;">
        <select id="nuevo-unit-${mKey}"
          onclick="event.stopPropagation()"
          style="flex:1;min-width:90px;font-size:.82rem;">
          ${UNIDADES.map(u=>`<option>${u}</option>`).join('')}
        </select>
        <button class="btn btn-rust btn-sm"
          onclick="addNuevoPendiente(event,'${mKey}')">
          ➕ Agregar
        </button>
      </div>
    </div>`;

  dd.innerHTML=html;
  dd.classList.add('open');
}

function hideIngDD(mKey){
  setTimeout(()=>{
    const dd=document.getElementById(`ing-dd-${mKey}`);
    if(!dd) return;
    // Don't close if focus is inside the dropdown itself
    const active=document.activeElement;
    if(dd.contains(active)) return;
    dd.classList.remove('open');
  },200);
}

async function addNuevoPendiente(e,mKey){
  e.preventDefault();
  e.stopPropagation();
  const nombreEl=document.getElementById(`nuevo-nombre-${mKey}`);
  const qtyEl=document.getElementById(`nuevo-qty-${mKey}`);
  const unitEl=document.getElementById(`nuevo-unit-${mKey}`);
  const nombre=(nombreEl?.value||'').trim();
  if(!nombre){nombreEl?.focus();toast('Escribe el nombre del ingrediente',true);return;}
  const qty=parseFloat(qtyEl?.value)||1;
  const unit=unitEl?.value||'unidad';

  // 1. Crear en Pendientes
  const{data,error}=await sb.from('pendientes')
    .insert({nombre,cantidad:String(qty),unidad:unit,done:false})
    .select().single();
  if(error){toast('Error al agregar pendiente',true);return;}
  if(data) pendientesCache.push(data);

  // 2. Agregar al ingQueue del menú como tipo "pendiente"
  if(!ingQueue[mKey]) ingQueue[mKey]=[];
  const alreadyInQueue=ingQueue[mKey].some(x=>x.nombre.toLowerCase()===nombre.toLowerCase());
  const alreadyInMeal=(menuCache[mKey]?.ingredientes||[]).some(x=>x.nombre.toLowerCase()===nombre.toLowerCase());
  if(!alreadyInQueue&&!alreadyInMeal){
    ingQueue[mKey].push({nombre,tipo:'pendiente',cantidad:qty,unidad:unit});
    renderIngQueue(mKey);
  }

  // 3. Limpiar campo y cerrar dropdown
  if(nombreEl){nombreEl.value='';}
  if(qtyEl) qtyEl.value='1';
  const dd=document.getElementById(`ing-dd-${mKey}`);
  if(dd) dd.classList.remove('open');

  toast(`✓ "${nombre}" agregado a pendientes`);
  renderPendientes();
}

function selectIng(e,mKey,nombre,tipo,defaultUnit){
  e.preventDefault();
  document.getElementById(`ing-dd-${mKey}`).classList.remove('open');
  document.getElementById(`ing-search-${mKey}`).value='';

  // Check not already in confirmed list
  const already=(menuCache[mKey]?.ingredientes||[]).some(x=>x.nombre.toLowerCase()===nombre.toLowerCase());
  if(already){toast(`"${nombre}" ya está en la receta`,true);return;}

  // Check not already in queue
  const queue=ingQueue[mKey]||[];
  if(queue.some(x=>x.nombre.toLowerCase()===nombre.toLowerCase())){
    toast(`"${nombre}" ya está en la lista de espera`,true);return;
  }

  // Add to queue
  if(!ingQueue[mKey]) ingQueue[mKey]=[];
  ingQueue[mKey].push({nombre,tipo,cantidad:1,unidad:defaultUnit||'unidad'});
  renderIngQueue(mKey);
}

function renderIngQueue(mKey){
  const queue=ingQueue[mKey]||[];
  const qWrap=document.getElementById(`ing-queue-${mKey}`);
  const btn=document.getElementById(`ing-queue-btn-${mKey}`);
  const grid=document.getElementById(`grid-${mKey}`);
  if(!qWrap)return;

  if(!queue.length){
    qWrap.innerHTML='';
    if(btn) btn.classList.remove('visible');
    return;
  }

  qWrap.innerHTML=queue.map((item,i)=>`
    <div class="ing-queue-item">
      <span class="iq-name">${esc(item.nombre)}</span>
      <span class="iq-badge ${item.tipo==='comprado'?'badge-comprado':'badge-pendiente'}">${item.tipo==='comprado'?'comprado':'pendiente'}</span>
      <input type="number" value="${item.cantidad}" min="0.01" step="0.01"
        onchange="ingQueue['${mKey}'][${i}].cantidad=parseFloat(this.value)||1"
        title="Cantidad">
      <select onchange="ingQueue['${mKey}'][${i}].unidad=this.value" title="Unidad">
        ${UNIDADES.map(u=>`<option ${u===item.unidad?'selected':''}>${u}</option>`).join('')}
      </select>
      <button class="iq-del" onclick="removeFromQueue('${mKey}',${i})">✕</button>
    </div>`
  ).join('');

  if(btn) btn.classList.add('visible');

  // Stack layout when queue has items
  if(grid && queue.length>0) grid.classList.add('stacked');
}

function removeFromQueue(mKey,idx){
  if(!ingQueue[mKey])return;
  ingQueue[mKey].splice(idx,1);
  renderIngQueue(mKey);
  if(!ingQueue[mKey].length){
    const grid=document.getElementById(`grid-${mKey}`);
    if(grid) grid.classList.remove('stacked');
  }
}

async function confirmAllIngs(mKey){
  const queue=ingQueue[mKey]||[];
  if(!queue.length)return;

  // mKey format: "YYYY-MM-DD-comida" — lastIndexOf('-') splits fecha from comida
  const lastDash=mKey.lastIndexOf('-');
  const fechaIso=mKey.slice(0,lastDash);
  const comida=mKey.slice(lastDash+1);

  // Ensure menu row exists
  await sb.from('menu_semana').upsert(
    {fecha_iso:fechaIso,comida,texto:menuCache[mKey]?.texto||''},
    {onConflict:'fecha_iso,comida',ignoreDuplicates:false}
  );

  const rows=queue.map(item=>({
    fecha_iso:fechaIso,
    comida,
    nombre:item.nombre,
    cantidad:String(item.cantidad),
    unidad:item.unidad,
    tipo:item.tipo
  }));

  const{data,error}=await sb.from('ingredientes').insert(rows).select();
  if(error){
    console.error('Error guardando ingredientes:',error);
    toast('Error: '+error.message,true);
    return;
  }
  if(data){
    if(!menuCache[mKey]) menuCache[mKey]={texto:'',ingredientes:[],db_id:null};
    data.forEach(d=>{
      menuCache[mKey].ingredientes.push({
        id:d.id,nombre:d.nombre,
        cantidad:Number(d.cantidad)||1,
        unidad:d.unidad,tipo:d.tipo
      });
    });
    for(const item of queue){
      await discountFromInventory(item.nombre,item.cantidad,item.unidad,item.tipo);
    }
    ingQueue[mKey]=[];
    renderIngQueue(mKey);
    refreshChips(mKey);
    buildDaysList();
    renderInventario();
    toast(`${data.length} ingrediente${data.length!==1?'s':''} guardado${data.length!==1?'s':''}`);
  }
}

async function removeIngFromMeal(mKey,idx){
  const m=menuCache[mKey];
  if(!m)return;
  const ing=m.ingredientes[idx];
  if(!ing)return;
  await sb.from('ingredientes').delete().eq('id',ing.id);
  // Devolver al inventario
  await returnToInventory(ing.nombre, ing.cantidad, ing.unidad, ing.tipo);
  m.ingredientes.splice(idx,1);
  toast('Ingrediente quitado');
  refreshChips(mKey);
  buildDaysList();
  renderInventario();
}

function refreshChips(mKey){
  const wrap=document.getElementById(`sel-ings-${mKey}`);
  if(!wrap)return;
  const m=menuCache[mKey]||{ingredientes:[]};
  wrap.innerHTML=m.ingredientes.map((ing,i)=>
    `<span class="sel-chip ${ing.tipo}" data-mkey="${esc(mKey)}" data-idx="${i}">
      ${esc(ing.nombre)}<span class="chip-qty">${ing.cantidad} ${ing.unidad}</span>
      <span class="chip-del" onclick="removeIngFromMeal('${esc(mKey)}',${i})">✕</span>
    </span>`
  ).join('');
}

