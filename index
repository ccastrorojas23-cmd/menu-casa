  toast('Presupuesto guardado');updatePresUI();closeBudgetModal();
}

// ══════════════════════════════════════
//  PENDIENTES
// ══════════════════════════════════════
async function addPendiente(){
  const nombre=document.getElementById('p-nombre').value.trim();
  if(!nombre)return;
  const qty=document.getElementById('p-qty').value||'1';
  const unit=document.getElementById('p-unit').value;
  const{data,error}=await sb.from('pendientes').insert({nombre,cantidad:qty,unidad:unit,done:false}).select().single();
  if(!error&&data){
    pendientesCache.push(data);
    document.getElementById('p-nombre').value='';
    document.getElementById('p-qty').value='';
    toast('Guardado');renderPendientes();
  }
}
async function togglePend(id,val){
  await sb.from('pendientes').update({done:val}).eq('id',id);
  const p=pendientesCache.find(x=>x.id===id);
  if(p){p.done=val;renderPendientes();}
  toast(val?'Marcado ✓':'Desmarcado');
}
async function delPend(id){
  await sb.from('pendientes').delete().eq('id',id);
  pendientesCache=pendientesCache.filter(x=>x.id!==id);
  toast('Eliminado');renderPendientes();
}
async function clearPendientes(){
  const ok=await conf('🗑️ Limpiar','¿Eliminar todos los pendientes?');
  if(!ok)return;
  await sb.from('pendientes').delete().neq('id','00000000-0000-0000-0000-000000000000');
  pendientesCache=[];toast('Listo');renderPendientes();
}
function renderPendientes(){
  const wrap=document.getElementById('pend-list');
  if(!pendientesCache.length){wrap.innerHTML='<div class="empty"><div class="empty-icon">✅</div><p>¡Sin pendientes!</p></div>';return;}
  wrap.innerHTML=`<div style="display:flex;flex-direction:column;gap:.45rem;">${pendientesCache.map(p=>`
    <div class="pend-item ${p.done?'done':''}">
      <input type="checkbox" ${p.done?'checked':''} onchange="togglePend('${p.id}',this.checked)">
      <span style="flex:1;">${esc(p.nombre)}</span>
      <span style="font-size:.75rem;color:var(--muted);">${p.cantidad||'1'} ${p.unidad||''}</span>
      <button class="btn btn-danger btn-xs" onclick="delPend('${p.id}')">✕</button>
    </div>`).join('')}</div>`;
}

// ══════════════════════════════════════
//  HISTORIAL
// ══════════════════════════════════════
function renderHistorial(){
  const wrap=document.getElementById('hist-wrap');
  if(!histCache.length){wrap.innerHTML='<div class="empty"><div class="empty-icon">🗂️</div><p>Sin historial.</p></div>';return;}
  const groups={};
  histCache.forEach(c=>{const k=c.periodo||'Sin fecha';if(!groups[k])groups[k]=[];groups[k].push(c);});
  wrap.innerHTML=Object.entries(groups).map(([periodo,rows])=>{
    const total=rows.reduce((s,r)=>s+Number(r.costo||0),0);
    return`<div class="hist-block">
      <div class="hist-head" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'block':'none'">
        <span>📅 ${periodo} · ${rows.length} artículos · $${total.toLocaleString('es-CO')}</span><span>▾</span>
      </div>
      <div style="display:none;">
        <table class="ct" style="margin-bottom:.5rem;">
          <thead><tr><th>Artículo</th><th>Categoría</th><th>Cantidad</th><th>Costo</th><th>Tienda</th></tr></thead>
          <tbody>${rows.map(r=>`<tr><td>${esc(r.nombre||'')}</td><td>${r.categoria||'—'}</td><td>${r.cantidad||'1'} ${r.unidad||''}</td><td>$${Number(r.costo||0).toLocaleString('es-CO')}</td><td>${r.tienda||'—'}</td></tr>`).join('')}</tbody>
        </table>
      </div>
    </div>`;
  }).join('');
}

// ══════════════════════════════════════
//  RESET QUINCENA
// ══════════════════════════════════════
async function resetQ(){
  const ok=await conf(`🔄 Reiniciar Q${currentQ}`,`Se borrarán todas las recetas e ingredientes de los días ${currentQ===1?'1–15':'16–30'} de la quincena actual.`);
  if(!ok)return;
  // Get the date range for this quincena
  const dates=getQDates();
  const isoList=dates.map(d=>d.isoDate);
  // Delete by fecha_iso for new records, and by quincena for old records
  const qKey=`Q${currentQ}`;
  await Promise.all([
    sb.from('menu_semana').delete().in('fecha_iso',isoList),
    sb.from('ingredientes').delete().in('fecha_iso',isoList),
    sb.from('menu_semana').delete().eq('quincena',qKey),
    sb.from('ingredientes').delete().eq('quincena',qKey)
  ]);
  // Clear cache
  Object.keys(menuCache).filter(k=>{
    return isoList.some(iso=>k.startsWith(iso))||k.startsWith(qKey);
  }).forEach(k=>delete menuCache[k]);
  activeDay=null;
  closePanel();
  toast('Quincena reiniciada');
  buildDaysList();
}

// ══════════════════════════════════════
//  REALTIME
// ══════════════════════════════════════
function setupRT(){
  sb.channel('rt-menu')
    .on('postgres_changes',{event:'*',schema:'public',table:'compras'},async()=>{
      const{data}=await sb.from('compras').select('*').order('created_at',{ascending:false});
      comprasCache=data||[];renderCompras();updatePresUI();updateDailyTotal();
    })
    .on('postgres_changes',{event:'*',schema:'public',table:'inventario'},async()=>{
      const{data}=await sb.from('inventario').select('*').order('nombre',{ascending:true});
      inventarioCache=data||[];renderInventario();
    })
    .on('postgres_changes',{event:'*',schema:'public',table:'pendientes'},async()=>{
      const{data}=await sb.from('pendientes').select('*').order('created_at',{ascending:true});
      pendientesCache=data||[];renderPendientes();renderInventario();
    })
    .subscribe();
}

// ══════════════════════════════════════
//  INIT
// ══════════════════════════════════════
async function init(){
  // Set today's date as default in fecha input
  const todayISO=new Date().toISOString().slice(0,10);
  const fechaEl=document.getElementById('c-fecha');
  if(fechaEl) fechaEl.value=todayISO;

  await loadAll();
  buildMosaic();
  renderCompras();
  updatePresUI();
  updateDailyTotal();
  renderPendientes();
  setupRT();
  scheduleMidnightReset();
  const ls=document.getElementById('loading');
  ls.classList.add('hide');
  setTimeout(()=>ls.remove(),600);
}
init();
</script>
