<!-- APP SHELL -->
<div class="app-shell">

<!-- CONTENT TOPBAR -->
<div class="content-topbar">
  <span class="ct-title" id="ct-title">📅 Menú Semanal</span>
  <div class="ct-actions" id="ct-actions"></div>
</div>

<main>

<!-- ══ MENÚ ══ -->
<section id="s-menu" class="sec on">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.7rem;margin-bottom:1.2rem;">
    <div class="q-tabs">
      <div class="q-tab on" onclick="setQ(1,this)">Días 1 – 15</div>
      <div class="q-tab" onclick="setQ(2,this)">Días 16 – 30</div>
    </div>
    <button class="btn btn-danger btn-sm" onclick="resetQ()">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3"/></svg>
      Reiniciar quincena
    </button>
  </div>
  <!-- Mosaic grid of day cards -->
  <div class="menu-mosaic" id="menu-mosaic"></div>
  <!-- Selected day panel -->
  <div id="day-panel-wrap" style="margin-top:1.2rem;">
    <div class="day-panel-empty"><div class="ei">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </div><p>Selecciona un día para planificar su menú</p></div>
  </div>
</section>

<!-- ══ FAVORITOS ══ -->
<section id="s-favoritos" class="sec">
  <div class="ptitle">
    <span>⭐ Recetas Favoritas</span>
    <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;">
      <select id="fav-filter-comida" onchange="renderFavoritos()" style="font-size:.8rem;">
        <option value="">Todas las comidas</option>
        <option value="desayuno">☕ Desayuno</option>
        <option value="almuerzo">🍽️ Almuerzo</option>
        <option value="comida">🌙 Comida</option>
      </select>
      <input type="text" id="fav-search" placeholder="Buscar receta…" oninput="renderFavoritos()" style="font-size:.8rem;max-width:200px;">
    </div>
  </div>
  <div id="fav-grid" class="fav-grid"></div>
</section>

<!-- ══ INVENTARIO ══ -->
<section id="s-inventario" class="sec">
  <div class="ptitle">📦 Inventario de Alimentos</div>
  <p style="font-size:.83rem;color:var(--muted);margin-bottom:1.2rem;">
    Muestra todos los alimentos comprados y pendientes. Las cantidades se descuentan automáticamente cuando los asignas a recetas del menú.
  </p>
  <div class="inv-layout">
    <div class="inv-card">
      <div class="inv-card-header comprado">✅ Comprados <span id="inv-comp-count" style="font-size:.75rem;opacity:.7;"></span></div>
      <div id="inv-comprados"></div>
    </div>
    <div class="inv-card">
      <div class="inv-card-header pendiente">⏳ Pendientes por comprar <span id="inv-pend-count" style="font-size:.75rem;opacity:.7;"></span></div>
      <div id="inv-pendientes"></div>
    </div>
  </div>
</section>

<!-- ══ COMPRAS ══ -->
<section id="s-compras" class="sec">
  <div class="ptitle">
