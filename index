<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Menú Casa</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root{
  --bg:#f0ede8;
  --surface:#ffffff;
  --surface2:#f5f2ed;
  --ink:#1a1917;
  --muted:#7a756d;
  --border:#ddd9d2;
  --sage:#2d4a3e;
  --sage-m:#3d6b5e;
  --sage-l:#4e8a7a;
  --sage-pale:#e6f0ed;
  --rust:#b84422;
  --rust-l:#d4572e;
  --rust-pale:#faeae4;
  --amber:#c08b28;
  --amber-pale:#fdf4e0;
  --shadow-sm:0 2px 8px rgba(26,25,23,.08);
  --shadow:0 4px 20px rgba(26,25,23,.11);
  --shadow-lg:0 12px 40px rgba(26,25,23,.16);
  --r:12px;
  --sidebar:56px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Jost',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh;display:flex;}

/* ══ SIDEBAR ══ */
.sidebar{
  width:var(--sidebar);flex-shrink:0;
  background:#1a2e28;
  display:flex;flex-direction:column;align-items:center;
  padding:14px 0 10px;position:fixed;left:0;top:0;bottom:0;z-index:400;
  box-shadow:2px 0 16px rgba(0,0,0,.18);
}
.sb-logo{
  width:34px;height:34px;border-radius:10px;
  background:var(--sage-m);display:flex;align-items:center;
  justify-content:center;font-size:1.1rem;margin-bottom:20px;
  box-shadow:0 2px 8px rgba(0,0,0,.25);flex-shrink:0;
}
.sb-nav{display:flex;flex-direction:column;gap:4px;align-items:center;flex:1;width:100%;}
.sb-item{
  width:40px;height:40px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all .2s;position:relative;
  color:#7a9e94;font-size:1.15rem;
}
.sb-item:hover{background:rgba(255,255,255,.08);color:#b0d0c8;}
.sb-item.on{background:#2d5a47;color:#6ee7b7;}
.sb-item.on::before{
  content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);
  width:3px;height:22px;background:#6ee7b7;border-radius:0 3px 3px 0;
}
.sb-tooltip{
  position:absolute;left:calc(var(--sidebar) + 8px);
  background:#1a2e28;color:#e0f0ec;font-size:.75rem;font-weight:600;
  padding:.3rem .7rem;border-radius:7px;white-space:nowrap;
  opacity:0;pointer-events:none;transition:opacity .15s;z-index:500;
  box-shadow:var(--shadow);
}
.sb-item:hover .sb-tooltip{opacity:1;}
.sb-divider{width:24px;height:1px;background:rgba(255,255,255,.08);margin:6px 0;}
.sb-bottom{margin-top:auto;display:flex;flex-direction:column;align-items:center;gap:8px;padding-bottom:4px;}
.sync-dot{width:7px;height:7px;border-radius:50%;background:#6ee7b7;}
.sync-dot.err{background:#f87171;}
.pres-btn{
  width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,.08);
  border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;
  color:#b0d0c8;font-size:.8rem;flex-direction:column;gap:1px;transition:.2s;
  font-family:'Jost',sans-serif;
}
.pres-btn:hover{background:rgba(255,255,255,.15);}
.pres-btn .pres-icon{font-size:.9rem;}
.pres-btn .pres-amt{font-size:.58rem;opacity:.8;font-weight:600;}

/* Mobile topbar (visible only on mobile) */
.mobile-topbar{
  display:none;background:#1a2e28;height:52px;
  align-items:center;justify-content:space-between;
  padding:0 1rem;position:fixed;top:0;left:0;right:0;z-index:400;
  box-shadow:0 2px 12px rgba(0,0,0,.2);
}
.mob-logo{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:.4rem;}
.mob-right{display:flex;align-items:center;gap:.7rem;}
.mob-pres{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);padding:.25rem .7rem;border-radius:20px;font-size:.78rem;color:#fff;cursor:pointer;}
.mob-menu-btn{
  width:34px;height:34px;border-radius:8px;background:rgba(255,255,255,.1);
  border:none;cursor:pointer;display:flex;flex-direction:column;align-items:center;
  justify-content:center;gap:4px;
}
.mob-menu-btn span{width:14px;height:1.5px;background:#fff;border-radius:2px;transition:.2s;}

/* Mobile drawer overlay */
.mob-overlay{
  display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:350;
  backdrop-filter:blur(2px);
}
.mob-overlay.open{display:block;}
.mob-drawer{
  position:fixed;left:0;top:0;bottom:0;width:220px;background:#1a2e28;z-index:360;
  display:flex;flex-direction:column;padding:60px 0 16px;
  transform:translateX(-100%);transition:transform .3s cubic-bezier(.4,0,.2,1);
  box-shadow:4px 0 24px rgba(0,0,0,.3);
}
.mob-drawer.open{transform:translateX(0);}
.mob-drawer-item{
  display:flex;align-items:center;gap:.75rem;padding:.75rem 1.2rem;
  font-size:.88rem;color:#7a9e94;cursor:pointer;transition:.15s;
}
.mob-drawer-item:hover{background:rgba(255,255,255,.06);color:#b0d0c8;}
.mob-drawer-item.on{color:#6ee7b7;background:#2d5a47;}
.mob-drawer-item .di-icon{font-size:1rem;width:20px;text-align:center;}
.mob-drawer-divider{height:1px;background:rgba(255,255,255,.07);margin:6px 1.2rem;}

/* ══ APP SHELL ══ */
.app-shell{
  margin-left:var(--sidebar);flex:1;
  display:flex;flex-direction:column;min-height:100vh;
}

/* ══ TOPBAR (content area) ══ */
.content-topbar{
  background:var(--surface);border-bottom:1px solid var(--border);
  height:52px;display:flex;align-items:center;justify-content:space-between;
  padding:0 1.5rem;position:sticky;top:0;z-index:200;
  box-shadow:var(--shadow-sm);
}
.ct-title{font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:700;color:var(--sage);}
.ct-actions{display:flex;align-items:center;gap:.6rem;}

/* ══ MAIN ══ */
main{padding:1.5rem;flex:1;}
@media(max-width:600px){main{padding:.75rem;}}
.sec{display:none;}
.sec.on{display:block;animation:fadeUp .25s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:none}}

/* ── PAGE TITLE ── */
.ptitle{font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:700;color:var(--sage);margin-bottom:1.2rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.7rem;}
@media(max-width:600px){.ptitle{font-size:1.1rem;}}

/* ── BTNS ── */
.btn{padding:.5rem 1rem;border-radius:9px;border:none;font-family:'Jost',sans-serif;font-weight:600;font-size:.81rem;cursor:pointer;transition:.18s;display:inline-flex;align-items:center;gap:.32rem;}
.btn:active{transform:scale(.97);}
.btn-sage{background:var(--sage);color:#fff;} .btn-sage:hover{background:var(--sage-l);}
.btn-rust{background:var(--rust);color:#fff;} .btn-rust:hover{background:var(--rust-l);}
.btn-amber{background:var(--amber);color:#fff;} .btn-amber:hover{filter:brightness(1.1);}
.btn-preparado-off{background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.4);}
.btn-preparado-off:hover{background:rgba(255,255,255,.28);}
.btn-preparado-on{background:#1a7a50;color:#fff;border:1px solid #155f3e;}
.btn-preparado-on:hover{background:#15663f;}
.btn-ghost{background:var(--surface2);color:var(--ink);border:1px solid var(--border);} .btn-ghost:hover{background:var(--border);}
.btn-danger{background:var(--rust-pale);color:var(--rust);border:1px solid #ecca be;} .btn-danger:hover{background:#f5d4c8;}
.btn-sm{padding:.32rem .72rem;font-size:.75rem;}
.btn-xs{padding:.2rem .5rem;font-size:.7rem;}

/* ── FORMS ── */
.fg{display:flex;flex-direction:column;gap:.22rem;}
.fg label{font-size:.68rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.45px;}
input,select,textarea{border:1px solid var(--border);border-radius:8px;padding:.48rem .75rem;font-size:.84rem;font-family:'Jost',sans-serif;color:var(--ink);background:var(--surface2);transition:.2s;}
input:focus,select:focus,textarea:focus{outline:none;border-color:var(--sage-l);box-shadow:0 0 0 3px rgba(61,107,94,.13);background:#fff;}
.form-row{display:flex;gap:.65rem;flex-wrap:wrap;align-items:flex-end;margin-bottom:.85rem;}

/* ── QUINCENA TABS ── */
.q-tabs{display:flex;gap:.5rem;margin-bottom:1.2rem;}
.q-tab{padding:.42rem 1rem;border-radius:20px;font-size:.8rem;font-weight:700;border:1.5px solid var(--border);background:var(--surface);color:var(--muted);cursor:pointer;transition:.2s;}
.q-tab.on{background:var(--sage);color:#fff;border-color:var(--sage);}
.q-tab:hover:not(.on){border-color:var(--sage);color:var(--sage);}

/* ══════════════════════════════════════════
   MENÚ — LISTA DE DÍAS (izquierda)
══════════════════════════════════════════ */
.menu-layout{display:grid;grid-template-columns:300px 1fr;gap:1.2rem;align-items:start;}
@media(max-width:860px){.menu-layout{grid-template-columns:1fr;}}

.days-list{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow-sm);}
.day-item{
  display:flex;align-items:center;justify-content:space-between;
  padding:.85rem 1.1rem;border-bottom:1px solid var(--border);
  cursor:pointer;transition:var(--transition);user-select:none;
}
.day-item:last-child{border-bottom:none;}
.day-item:hover{background:var(--sage-pale);}
.day-item.active{background:var(--sage);color:#fff;}
.day-item.active .day-status{color:rgba(255,255,255,.75);}
.day-left{display:flex;flex-direction:column;gap:.12rem;}
.day-name{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:700;}
.day-date-small{font-size:.7rem;color:var(--muted);}
.day-item.active .day-date-small{color:rgba(255,255,255,.7);}
.day-status{font-size:.68rem;font-weight:600;display:flex;align-items:center;gap:.25rem;}
.dot-plan{color:var(--sage-l);} .day-item.active .dot-plan{color:#a8f0e0;}
.dot-no{color:var(--muted);}
.today-badge{font-size:.62rem;background:var(--rust);color:#fff;padding:.1rem .45rem;border-radius:10px;font-weight:700;margin-left:.4rem;}

/* ══════════════════════════════════════════
   PANEL CENTRAL — DESKTOP
══════════════════════════════════════════ */
.day-panel{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--r);
  box-shadow:var(--shadow);
  animation:panelIn .35s cubic-bezier(.34,1.3,.64,1);
  transform-origin:top left;
}
@keyframes panelIn{
  from{opacity:0;transform:scale(.97) translateY(12px);}
  to{opacity:1;transform:scale(1) translateY(0);}
}
.day-panel-empty{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  min-height:380px;color:var(--muted);text-align:center;gap:.6rem;
  background:var(--surface);border:1.5px dashed var(--border);border-radius:var(--r);
}
.day-panel-empty .ei{font-size:2.5rem;}
.day-panel-empty p{font-size:.88rem;}

/* ══ PANEL MÓVIL — aparece como modal fullscreen ══ */
.day-modal-overlay{
  display:none;position:fixed;inset:0;z-index:800;
  background:rgba(30,28,24,.6);backdrop-filter:blur(4px);
  align-items:flex-end;justify-content:center;
}
.day-modal-overlay.open{display:flex;}
.day-modal-sheet{
  background:var(--surface);width:100%;max-height:92vh;
  border-radius:22px 22px 0 0;overflow-y:auto;
  animation:sheetUp .38s cubic-bezier(.34,1.2,.64,1);
  box-shadow:0 -8px 40px rgba(30,28,24,.22);
}
@keyframes sheetUp{
  from{transform:translateY(100%);}
  to{transform:translateY(0);}
}
.sheet-handle{width:40px;height:4px;background:var(--border);border-radius:2px;margin:.75rem auto .5rem;}

.dp-header{
  background:linear-gradient(135deg,var(--sage),var(--sage-l));
  color:#fff;padding:1.1rem 1.4rem;border-radius:var(--r) var(--r) 0 0;
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;
}
.dp-title{font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:700;}
.dp-date{font-size:.78rem;opacity:.8;margin-top:.1rem;}

.dp-body{padding:1.2rem;}
@media(max-width:860px){.dp-body{padding:.85rem;}}

.meal-section{margin-bottom:1.4rem;border:1px solid var(--border);border-radius:12px;overflow:hidden;}
.meal-section:last-child{margin-bottom:0;}
.ms-header{
  background:var(--surface2);padding:.65rem 1rem;
  display:flex;align-items:center;gap:.5rem;
  border-bottom:1px solid var(--border);
}
.ms-icon{font-size:1.1rem;}
.ms-label{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:700;color:var(--sage);}

.ms-body{padding:1rem;}
@media(max-width:600px){.ms-body{padding:.7rem;}}
.ms-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;align-items:start;}
@media(max-width:640px){.ms-grid{grid-template-columns:1fr;}}
.ms-grid.stacked{grid-template-columns:1fr;}
.recipe-box{width:100%;min-height:80px;resize:vertical;font-size:.84rem;line-height:1.55;border-radius:9px;}

/* Ingredientes del menú */
.ing-selector-wrap{display:flex;flex-direction:column;gap:.5rem;}
.ing-selector-label{font-size:.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;}

/* Queue de ingredientes pendientes de confirmar cantidad */
.ing-queue{display:flex;flex-direction:column;gap:.35rem;margin-top:.4rem;}
.ing-queue-item{
  display:flex;align-items:center;gap:.4rem;
  background:var(--amber-pale);border:1px solid #e8c87a;
  border-radius:9px;padding:.4rem .65rem;font-size:.82rem;
  animation:fadeUp .18s ease;
}
.ing-queue-item .iq-name{flex:1;font-weight:600;color:var(--ink);}
.ing-queue-item .iq-badge{font-size:.66rem;padding:.1rem .4rem;border-radius:10px;font-weight:700;}
.ing-queue-item input[type=number]{width:60px;padding:.3rem .5rem;font-size:.8rem;}
.ing-queue-item select{min-width:100px;padding:.3rem .5rem;font-size:.8rem;}
.ing-queue-item .iq-del{background:none;border:none;color:var(--muted);cursor:pointer;font-size:.9rem;flex-shrink:0;}
.ing-queue-item .iq-del:hover{color:var(--rust);}
.ing-queue-confirm{
  display:none;margin-top:.3rem;
  padding:.5rem .8rem;background:var(--sage);color:#fff;
  border:none;border-radius:9px;font-family:'Jost',sans-serif;
  font-weight:700;font-size:.8rem;cursor:pointer;width:100%;
  transition:.18s;
}
.ing-queue-confirm:hover{background:var(--sage-l);}
.ing-queue-confirm.visible{display:block;}

/* Dropdown ingredientes — mobile aware */
.ing-sel-row{display:flex;gap:.4rem;position:relative;}
.ing-sel-row input{flex:1;}
.ing-dd{
  position:fixed;
  background:#fff;border:1px solid var(--border);border-radius:12px;
  box-shadow:var(--shadow-lg);z-index:900;
  width:min(380px, calc(100vw - 24px));
  max-height:min(380px, 45vh);
  overflow-y:auto;
  display:none;
}
.ing-dd.open{display:block;}
.ing-dd-sec{font-size:.65rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;padding:.35rem .85rem .15rem;background:var(--surface2);position:sticky;top:0;}
.ing-dd-item{
  display:flex;align-items:center;justify-content:space-between;
  padding:.7rem .85rem;font-size:.84rem;cursor:pointer;border-bottom:1px solid var(--border);transition:.15s;
  min-height:48px;/* touch-friendly */
}
.ing-dd-item:last-child{border-bottom:none;}
.ing-dd-item:hover,.ing-dd-item:active{background:var(--sage-pale);}
.ing-dd-item .iname{flex:1;}
.ing-dd-item .istock{font-size:.72rem;color:var(--muted);margin:0 .5rem;}
.badge-comprado{background:var(--sage-pale);color:var(--sage);padding:.1rem .45rem;border-radius:10px;font-size:.66rem;font-weight:700;}
.badge-pendiente{background:var(--rust-pale);color:var(--rust);padding:.1rem .45rem;border-radius:10px;font-size:.66rem;font-weight:700;}
.ing-dd-nuevo{border-top:1px solid var(--border);background:var(--surface);}

/* Chips de ingredientes seleccionados */
.sel-ings{display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.4rem;}
.sel-chip{
  display:inline-flex;align-items:center;gap:.3rem;
  padding:.22rem .65rem;border-radius:20px;font-size:.74rem;font-weight:600;
}
.sel-chip.comprado{background:var(--sage-pale);color:var(--sage);border:1px solid #b8d8d1;}
.sel-chip.pendiente{background:var(--rust-pale);color:var(--rust);border:1px solid #ecc0ad;}
.sel-chip .chip-del{cursor:pointer;opacity:.6;font-size:.8rem;margin-left:.1rem;}
.sel-chip .chip-del:hover{opacity:1;}
.chip-qty{font-size:.68rem;opacity:.75;margin-left:.15rem;}

/* ══ INVENTARIO ══ */
.inv-layout{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;}
@media(max-width:860px){.inv-layout{grid-template-columns:1fr;}}
.inv-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow-sm);}
.inv-card-header{padding:.8rem 1.1rem;font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:700;display:flex;align-items:center;justify-content:space-between;}
.inv-card-header.comprado{background:var(--sage-pale);color:var(--sage);}
.inv-card-header.pendiente{background:var(--rust-pale);color:var(--rust);}
.inv-table{width:100%;border-collapse:collapse;font-size:.82rem;}
.inv-table th{text-align:left;padding:.48rem .8rem;font-size:.65rem;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);border-bottom:2px solid var(--border);}
.inv-table td{padding:.55rem .8rem;border-bottom:1px solid var(--border);vertical-align:middle;}
.inv-table tr:hover td{background:var(--surface2);}
.stock-pill{display:inline-block;padding:.15rem .5rem;border-radius:20px;font-size:.7rem;font-weight:700;}
.stock-ok{background:var(--sage-pale);color:var(--sage);}
.stock-low{background:var(--amber-pale);color:var(--amber);}
.stock-out{background:var(--rust-pale);color:var(--rust);}

/* ══ COMPRAS ══ */
.pres-strip{display:flex;align-items:center;gap:1.4rem;flex-wrap:wrap;background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:1.1rem 1.4rem;margin-bottom:1.2rem;box-shadow:var(--shadow-sm);}
.ps-g{display:flex;flex-direction:column;gap:.12rem;}
.ps-lbl{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);}
.ps-val{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:700;}
.ps-val.amber{color:var(--amber);} .ps-val.rust{color:var(--rust);} .ps-val.sage{color:var(--sage);} .ps-val.neg{color:var(--rust);}
.prog-w{flex:1;min-width:160px;}
.prog-b{height:9px;background:var(--surface2);border-radius:5px;overflow:hidden;margin-top:.4rem;border:1px solid var(--border);}
.prog-f{height:100%;background:var(--amber);border-radius:5px;transition:width .5s;}
.prog-f.danger{background:var(--rust);}

.ct{width:100%;border-collapse:collapse;font-size:.82rem;}
.ct th{text-align:left;padding:.48rem .8rem;font-size:.65rem;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);border-bottom:2px solid var(--border);}
.ct td{padding:.55rem .8rem;border-bottom:1px solid var(--border);vertical-align:middle;}
.ct tr:hover td{background:var(--surface2);}
.cat-badge{display:inline-block;padding:.14rem .5rem;border-radius:20px;font-size:.68rem;font-weight:700;background:var(--sage-pale);color:var(--sage);}

/* ══ COMPRAS FORM — responsive grid ══ */
.compra-form{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:.65rem;
  align-items:end;
}
.compra-nombre{grid-column:1/-1;}
.compra-btn{grid-column:1/-1;width:100%;justify-content:center;}
@media(max-width:600px){
  .compra-form{grid-template-columns:1fr;}
  .compra-nombre,.compra-cat,.compra-qty,.compra-costo,.compra-tienda,.compra-fecha{grid-column:1/-1;}
}

/* ══ PENDIENTES layout ══ */
.pend-layout{display:grid;grid-template-columns:1fr 1fr;gap:1.1rem;}
@media(max-width:700px){.pend-layout{grid-template-columns:1fr;}}

/* ══ INGREDIENTE DROPDOWN — mobile fix ══ */
.ing-dd{
  position:fixed;
  background:#fff;border:1px solid var(--border);border-radius:12px;
  box-shadow:var(--shadow-lg);z-index:900;
  width:min(380px, calc(100vw - 24px));
  max-height:min(380px, 45vh);
  overflow-y:auto;
  display:none;
}
.ing-dd.open{display:block;}

/* ══ PENDIENTES ══ */
.pend-item{display:flex;align-items:center;gap:.65rem;padding:.62rem .9rem;background:var(--surface2);border:1px solid var(--border);border-radius:9px;font-size:.83rem;transition:.2s;}
.pend-item.done{opacity:.4;text-decoration:line-through;}
.pend-item input[type=checkbox]{accent-color:var(--sage);width:15px;height:15px;cursor:pointer;flex-shrink:0;}
.hist-block{margin-bottom:.9rem;}
.hist-head{background:var(--sage-pale);color:var(--sage);padding:.55rem .9rem;border-radius:9px;cursor:pointer;display:flex;justify-content:space-between;font-size:.85rem;font-weight:600;margin-bottom:.3rem;}

/* ══ MODALS ══ */
.overlay{display:none;position:fixed;inset:0;background:rgba(30,28,24,.52);z-index:500;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.overlay.open{display:flex;}
.modal{background:var(--surface);border-radius:18px;padding:1.7rem;width:90%;max-width:480px;box-shadow:var(--shadow-lg);animation:slideUp .24s ease;max-height:88vh;overflow-y:auto;}
@keyframes slideUp{from{transform:translateY(16px);opacity:0}to{transform:none;opacity:1}}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:1.15rem;color:var(--sage);margin-bottom:1.1rem;display:flex;justify-content:space-between;align-items:center;}
.mcl{background:none;border:none;font-size:1.25rem;cursor:pointer;color:var(--muted);}
.mcl:hover{color:var(--rust);}

/* ══ TOAST + CONFIRM ══ */
#toast{position:fixed;bottom:1.1rem;right:1.1rem;background:var(--sage);color:#fff;padding:.48rem 1rem;border-radius:20px;font-size:.76rem;font-weight:700;box-shadow:var(--shadow);z-index:9999;opacity:0;transition:opacity .3s;pointer-events:none;}
#toast.show{opacity:1;}
#toast.err{background:var(--rust);}
.conf-overlay{display:none;position:fixed;inset:0;background:rgba(30,28,24,.5);z-index:600;align-items:center;justify-content:center;}
.conf-overlay.open{display:flex;}
.conf-box{background:#fff;border-radius:16px;padding:1.7rem;max-width:360px;width:90%;box-shadow:var(--shadow-lg);text-align:center;}
.conf-box h3{font-family:'Cormorant Garamond',serif;font-size:1.15rem;color:var(--ink);margin-bottom:.5rem;}
.conf-box p{font-size:.83rem;color:var(--muted);margin-bottom:1.3rem;line-height:1.5;}
.conf-act{display:flex;gap:.55rem;justify-content:center;}

/* ══ MOBILE ══ */
@media(max-width:768px){
  .sidebar{display:none;}
  .mobile-topbar{display:flex;}
  .app-shell{margin-left:0;margin-top:52px;}
  main{padding:.7rem;}
  .ptitle{font-size:1.05rem;gap:.5rem;}
  .btn{padding:.45rem .85rem;font-size:.78rem;}
  .btn-sm{padding:.3rem .6rem;font-size:.72rem;}
  .form-row{gap:.5rem;}
  input,select,textarea{font-size:.82rem;padding:.42rem .65rem;}
  .ct,.inv-table{font-size:.75rem;}
  .ct th,.inv-table th{padding:.35rem .5rem;font-size:.6rem;}
  .ct td,.inv-table td{padding:.4rem .5rem;}
  .pres-strip{padding:.8rem 1rem;gap:1rem;}
  .ps-val{font-size:1.1rem;}
  .inv-layout{grid-template-columns:1fr;}
  #s-pendientes .pend-layout{grid-template-columns:1fr;}
  .fav-grid{grid-template-columns:1fr;}
  .ing-queue-item{flex-wrap:wrap;gap:.3rem;}
  .ing-queue-item input[type=number]{width:55px;}
  .ing-queue-item select{min-width:90px;}
  .content-topbar{padding:0 .9rem;}
  .ct-title{font-size:.95rem;}
}
@media(min-width:769px){
  .mob-overlay,.mob-drawer,.mobile-topbar{display:none !important;}
}

/* ══ FAVORITOS ══ */
.fav-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.1rem;}
.fav-card{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--r);
  overflow:hidden;box-shadow:var(--shadow-sm);
  transition:box-shadow .2s, transform .2s;
}
.fav-card:hover{box-shadow:var(--shadow);transform:translateY(-2px);}
.fav-card-header{
  padding:.75rem 1rem;display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid var(--border);background:var(--surface2);
}
.fav-card-comida{display:flex;align-items:center;gap:.4rem;font-size:.75rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;}
.fav-card-actions{display:flex;gap:.3rem;}
.fav-star-btn{
  background:none;border:none;font-size:1.2rem;cursor:pointer;
  line-height:1;padding:.15rem;transition:transform .2s;
}
.fav-star-btn:hover{transform:scale(1.25);}
.fav-card-body{padding:1rem;}
.fav-nombre{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:700;color:var(--ink);margin-bottom:.35rem;}
.fav-desc{font-size:.82rem;color:var(--muted);line-height:1.5;margin-bottom:.7rem;}
.fav-ings{display:flex;flex-wrap:wrap;gap:.3rem;margin-bottom:.7rem;}
.fav-ing-chip{font-size:.7rem;padding:.15rem .5rem;border-radius:20px;font-weight:600;}
.fav-ing-chip.comprado{background:var(--sage-pale);color:var(--sage);}
.fav-ing-chip.pendiente{background:var(--rust-pale);color:var(--rust);}
.fav-usada{font-size:.68rem;color:var(--muted);margin-top:.3rem;}
.fav-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:3rem 1rem;color:var(--muted);text-align:center;gap:.5rem;grid-column:1/-1;}
.fav-empty .fav-empty-icon{font-size:2.5rem;}

/* Star button in meal section header */
.ms-fav-btn{
  margin-left:auto;background:none;border:none;font-size:1.1rem;
  cursor:pointer;padding:.1rem .3rem;border-radius:6px;transition:.2s;
  line-height:1;
}
.ms-fav-btn:hover{background:var(--amber-pale);}
.ms-fav-btn.active{color:#f59e0b;}

/* ══ MENU MOSAIC ══ */
.menu-mosaic{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(155px,1fr));
  gap:.85rem;
}
.mosaic-card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--r);overflow:hidden;cursor:pointer;
  transition:box-shadow .2s,transform .2s;
  box-shadow:var(--shadow-sm);
}
.mosaic-card:hover{box-shadow:var(--shadow);transform:translateY(-2px);}
.mosaic-card.active{border-color:var(--sage-m);box-shadow:0 0 0 2px var(--sage-m);}
.mosaic-card.today .mc-header{background:var(--rust);color:#fff;}
.mc-header{
  background:var(--sage);color:#fff;
  padding:.55rem .8rem;display:flex;align-items:center;justify-content:space-between;
}
.mc-day{font-family:'Cormorant Garamond',serif;font-size:.95rem;font-weight:700;}
.mc-date{font-size:.62rem;opacity:.75;}
.mc-today-pill{font-size:.58rem;background:rgba(255,255,255,.25);padding:.1rem .45rem;border-radius:10px;font-weight:700;}
.mc-body{padding:.65rem .8rem;display:flex;flex-direction:column;gap:.38rem;}
.mc-meal{display:flex;align-items:center;gap:.4rem;}
.mc-meal-icon{font-size:.75rem;width:16px;text-align:center;flex-shrink:0;}
.mc-meal-text{font-size:.72rem;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;}
.mc-meal-text.empty{color:var(--muted);font-style:italic;}
.mc-footer{padding:.45rem .8rem;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.mc-status{font-size:.65rem;font-weight:600;}
.mc-status.ok{color:var(--sage-l);}
.mc-status.prep{color:#2a9d6e;}
.mc-status.empty{color:var(--muted);}
.mc-ing-count{font-size:.62rem;color:var(--muted);}
@media(max-width:500px){
  .menu-mosaic{grid-template-columns:repeat(2,1fr);}
}

/* ══ CHARTS ══ */
.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.2rem;}
@media(max-width:700px){.charts-grid{grid-template-columns:1fr;}}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:1.1rem;box-shadow:var(--shadow-sm);}
.chart-title{font-size:.8rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.9rem;}
.chart-canvas-wrap{position:relative;height:180px;}
.chart-full{grid-column:1/-1;}

/* ══ LOADING ══ */
#loading{position:fixed;inset:0;background:var(--sage);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9998;transition:opacity .5s;}
#loading.hide{opacity:0;pointer-events:none;}
#loading h1{font-family:'Cormorant Garamond',serif;color:#fff;font-size:2rem;margin-bottom:.4rem;}
#loading p{color:rgba(255,255,255,.6);font-size:.87rem;margin-bottom:1.7rem;}
.ldots span{display:inline-block;width:9px;height:9px;background:rgba(255,255,255,.8);border-radius:50%;margin:0 3px;animation:bounce 1.1s infinite;}
.ldots span:nth-child(2){animation-delay:.18s;} .ldots span:nth-child(3){animation-delay:.36s;}
@keyframes bounce{0%,80%,100%{transform:scale(.65);opacity:.5}40%{transform:scale(1.1);opacity:1}}
.empty{text-align:center;padding:2rem 1rem;color:var(--muted);}
.empty-icon{font-size:2rem;margin-bottom:.4rem;}
.empty p{font-size:.84rem;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:1.3rem;box-shadow:var(--shadow-sm);}
.card-title{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:700;color:var(--sage);margin-bottom:.9rem;display:flex;align-items:center;gap:.4rem;}
</style>
</head>
<body>

<div id="loading"><h1>🍽️ Menú Casa</h1><p>Conectando con la nube…</p><div class="ldots"><span></span><span></span><span></span></div></div>
<div id="toast"></div>

<!-- CONFIRM -->
<div class="conf-overlay" id="conf-ov">
  <div class="conf-box">
    <h3 id="conf-title"></h3><p id="conf-msg"></p>
    <div class="conf-act">
      <button class="btn btn-ghost" onclick="confResolve(false)">Cancelar</button>
      <button class="btn btn-rust" onclick="confResolve(true)">Confirmar</button>
    </div>
  </div>
</div>

<!-- SIDEBAR (desktop) -->
<aside class="sidebar">
  <div class="sb-logo">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
  </div>
  <nav class="sb-nav">
    <div class="sb-item on" id="sbi-menu" onclick="showSec('menu',this)">
