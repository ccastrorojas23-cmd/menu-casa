  </div>
  <div class="mob-drawer-item" onclick="showSec('historial',this);closeMobMenu()">
    <svg class="di-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="12 8 12 12 14 14"/><path d="M3.05 11a9 9 0 1 1 .5 4"/></svg>Historial
